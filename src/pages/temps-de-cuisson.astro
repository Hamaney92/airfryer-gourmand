---
import Layout from '../layouts/Layout.astro';
import { SITE, getPublishedRecipes, catInfo } from '../lib/site';

// Tableau des temps construit à partir des recettes publiées (source unique de vérité).
const recipes = await getPublishedRecipes();
const rows = recipes
  .map((r) => ({
    title: r.data.title.split(' au air fryer')[0].split(' :')[0],
    slug: r.slug,
    cat: catInfo(r.data.category).label,
    temp: r.data.temp,
    time: (r.data.prepTime ?? 0) + (r.data.cookTime ?? 0) - (r.data.prepTime ?? 0),
    cook: r.data.cookTime,
  }))
  .sort((a, b) => a.title.localeCompare(b.title, 'fr'));

const title = 'Temps de cuisson air fryer : tableau + convertisseur four → air fryer';
const description =
  "Tableau des temps et températures de cuisson au air fryer par aliment, plus un convertisseur four vers air fryer. Réglages testés.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Convertisseur four → air fryer',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web',
  url: `${SITE.url}/temps-de-cuisson/`,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};
---
<Layout title={title} description={description} path="/temps-de-cuisson/" jsonLd={jsonLd}>
  <div class="wrap article">
    <h1>Temps de cuisson air fryer</h1>
    <p>Les réglages ci-dessous sont testés. La règle générale : par rapport au four, <b>baissez la température d'environ 20 °C</b> et <b>réduisez le temps de ~20 %</b>. Utilisez le convertisseur pour un calcul instantané.</p>

    <div class="card-box">
      <h2 style="margin-top:0">Convertisseur four → air fryer</h2>
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end">
        <label style="font-weight:700">Température four (°C)<br />
          <input id="ovenTemp" type="number" value="200" min="80" max="280" step="5" style="margin-top:6px;padding:10px 12px;border:1px solid var(--line);border-radius:10px;width:130px;font-size:1rem" />
        </label>
        <label style="font-weight:700">Temps four (min)<br />
          <input id="ovenTime" type="number" value="30" min="1" max="240" step="1" style="margin-top:6px;padding:10px 12px;border:1px solid var(--line);border-radius:10px;width:130px;font-size:1rem" />
        </label>
      </div>
      <div class="quick" style="margin-top:18px">
        <b>Au air fryer :</b> <span id="result">180 °C pendant 24 min</span>
      </div>
      <p class="note">Indicatif — vérifiez la cuisson et adaptez selon votre modèle. Préchauffez 2-3 min pour les résultats croustillants.</p>
    </div>

    <h2>Tableau des temps par aliment</h2>
    <p>{rows.length} aliments testés. Cliquez pour la recette détaillée.</p>
    <table class="rectable">
      <thead>
        <tr><th>Aliment</th><th>Catégorie</th><th>Température</th><th>Cuisson</th></tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td class="t"><a href={`/recettes/${r.slug}/`} style="color:var(--brand-d)">{r.title}</a></td>
            <td>{r.cat}</td>
            <td>{r.temp}</td>
            <td>{r.cook} min</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script is:inline>
    (function () {
      const t = document.getElementById('ovenTemp');
      const m = document.getElementById('ovenTime');
      const out = document.getElementById('result');
      function round5(n) { return Math.round(n / 5) * 5; }
      function calc() {
        const temp = Math.max(80, Math.min(280, Number(t.value) || 0));
        const time = Math.max(1, Number(m.value) || 0);
        const afTemp = round5(temp - 20);
        const afTime = Math.max(1, Math.round(time * 0.8));
        out.textContent = `${afTemp} °C pendant ${afTime} min`;
      }
      t.addEventListener('input', calc);
      m.addEventListener('input', calc);
      calc();
    })();
  </script>
</Layout>
