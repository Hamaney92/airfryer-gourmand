---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const recipes = (await getCollection('recipes')).filter((r) => r.data.pubDate.getTime() <= Date.now());
  return recipes.map((r) => ({ params: { slug: r.slug }, props: { recipe: r } }));
}
const { recipe } = Astro.props;
const d = recipe.data;
const { Content } = await recipe.render();

// Maillage interne : recettes liées (même catégorie en priorité)
const allRecipes = (await getCollection('recipes')).filter((r) => r.data.pubDate.getTime() <= Date.now());
const sameCat = allRecipes.filter((r) => r.slug !== recipe.slug && r.data.category === d.category);
const otherCat = allRecipes.filter((r) => r.slug !== recipe.slug && r.data.category !== d.category);
const related = [...sameCat, ...otherCat].slice(0, 4);

const fmtDate = (dt) => new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(dt);
const published = d.pubDate;
const updated = d.updatedDate && d.updatedDate.getTime() > d.pubDate.getTime() ? d.updatedDate : null;

const authorEntity = { "@type": "Organization", "name": d.author, "url": "https://airfryergourmand.fr/a-propos/" };

const recipeSchema = {
  "@context":"https://schema.org","@type":"Recipe",
  "name": d.title,
  "description": d.description,
  "recipeCategory": d.category,
  "keywords": d.keyword,
  "author": authorEntity,
  "publisher": { "@type": "Organization", "name": "Airfryer Gourmand", "url": "https://airfryergourmand.fr/" },
  "datePublished": published.toISOString().slice(0,10),
  "dateModified": (updated || published).toISOString().slice(0,10),
  "image": d.image ? [new URL(d.image, "https://airfryergourmand.fr/").href] : undefined,
  "prepTime": `PT${d.prepTime}M`,
  "cookTime": `PT${d.cookTime}M`,
  "totalTime": `PT${d.prepTime + d.cookTime}M`,
  "recipeYield": `${d.servings} personnes`,
  "recipeIngredient": d.ingredients,
  "recipeInstructions": d.steps.map((s)=>({ "@type":"HowToStep", "text": s })),
  "aggregateRating": d.reviews>0 ? { "@type":"AggregateRating", "ratingValue": d.rating, "reviewCount": d.reviews } : undefined,
};
const faqSchema = d.faq.length>0 ? {
  "@context":"https://schema.org","@type":"FAQPage",
  "mainEntity": d.faq.map((f)=>({ "@type":"Question","name":f.q,"acceptedAnswer":{ "@type":"Answer","text":f.a }}))
} : null;
---
<Base title={d.metaTitle || d.title} description={d.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(recipeSchema)} />
  {faqSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <div class="wrap">
    <article class="article">
      <div class="crumb"><a href="/">Accueil</a> › <a href="/recettes/">Recettes</a> › {d.category}</div>
      <h1>{d.title}</h1>
      <div class="byline">
        <span class="by-av" aria-hidden="true">🍟</span>
        <span>Par <a href="/a-propos/">{d.author}</a> · Publié le {fmtDate(published)}{updated && <> · Mis à jour le {fmtDate(updated)}</>}</span>
      </div>
      <div class="amETA">
        <span class="stars">★ {d.rating.toFixed(1)}</span>
        {d.reviews>0 && <span>{d.reviews} avis</span>}
        <span class="chip">⏱️ {d.prepTime + d.cookTime} min</span>
        <span class="chip">🌡️ {d.temp}</span>
        <span class="chip">🍽️ {d.servings} pers.</span>
      </div>
      <a class="jump" href="#recette">↓ Aller à la recette</a>
      {d.image ? <img src={d.image} alt={d.title} class="hero-img" style="width:100%;height:340px;object-fit:cover;border-radius:18px;margin-bottom:22px" /> : <div class="ph"><span>📷 Photo du plat</span></div>}

      <div class="quick"><b>En bref :</b> {d.quickAnswer}</div>

      <Content />

      {d.note && (
        <aside class="edito-note">
          <div class="edito-head"><span aria-hidden="true">💬</span> Le mot de la rédaction</div>
          <p>{d.note}</p>
        </aside>
      )}

      <div class="card-box" id="recette">
        <h2 style="margin-top:0">🥘 La recette pas à pas</h2>
        <h3>Ingrédients ({d.servings} personnes)</h3>
        <ul>{d.ingredients.map((i)=><li>{i}</li>)}</ul>
        <h3>Préparation</h3>
        <ol>{d.steps.map((s)=><li>{s}</li>)}</ol>
        {d.tips.length>0 && (<><h3>Astuces</h3><ul>{d.tips.map((t)=><li>{t}</li>)}</ul></>)}
      </div>

      {d.faq.length>0 && (
        <div class="faq">
          <h2>Questions fréquentes</h2>
          {d.faq.map((f)=>(<><h3>{f.q}</h3><p>{f.a}</p></>))}
        </div>
      )}

      <p style="margin-top:26px"><a class="cta" href="/temps-de-cuisson/">🌡️ Voir tous les temps de cuisson</a></p>

      <div class="author-box">
        <div class="author-av" aria-hidden="true">🍟</div>
        <div class="author-txt">
          <div class="author-name">{d.author}</div>
          <p>On cuisine, on rate, on recommence — puis on ne publie que les réglages qui marchent vraiment, du premier coup et avec ton modèle d'air fryer. Chaque recette indique le temps et la température exacts, testés contre des repères fiables. <a href="/a-propos/">En savoir plus sur nous →</a></p>
        </div>
      </div>

      {related.length>0 && (
        <div class="related" style="margin-top:34px;border-top:1px solid #f0e6dc;padding-top:22px">
          <h2 style="margin-top:0">🍽️ Recettes similaires</h2>
          <ul class="related-list" style="list-style:none;padding:0;margin:0;display:grid;gap:10px">
            {related.map((r)=>(
              <li><a href={`/recettes/${r.slug}/`} style="color:#e8590c;font-weight:600;text-decoration:none">{r.data.title}</a> <span style="color:#9a8c7d;font-size:.9em">· {r.data.category}</span></li>
            ))}
          </ul>
          <p style="margin-top:16px"><a href="/recettes/" style="color:#e8590c;font-weight:600">→ Toutes les recettes air fryer</a></p>
        </div>
      )}
    </article>
  </div>
</Base>
