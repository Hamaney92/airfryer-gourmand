---
import Layout from '../layouts/Layout.astro';
const title = 'Contact — Airfryer Gourmand';
const description = "Contactez l'équipe Airfryer Gourmand : questions, suggestions de recettes, corrections.";
---
<Layout title={title} description={description} path="/contact/">
  <div class="wrap article">
    <h1>Contact</h1>
    <p>Une question sur une recette, une suggestion, une correction de temps de cuisson ? On lit tout.</p>
    <div class="card-box">
      <p style="margin-top:0"><b>Email :</b> <a href="mailto:contact@airfryergourmand.fr" style="color:var(--brand-d);font-weight:700">contact@airfryergourmand.fr</a></p>
      <p>Précisez le nom de la recette concernée et votre modèle d'air fryer : ça nous aide à répondre vite et juste.</p>
    </div>
    <p><a href="/recettes/" class="cta">← Retour aux recettes</a></p>
  </div>
</Layout>
