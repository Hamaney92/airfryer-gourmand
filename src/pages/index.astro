---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { SITE, CATEGORIES, catInfo, getPublishedRecipes } from '../lib/site';

const recipes = await getPublishedRecipes();
const latest = recipes.slice(0, 8);

// Compte par catégorie pour les tuiles.
const counts = new Map<string, number>();
for (const r of recipes) {
  const s = catInfo(r.data.category).slug;
  counts.set(s, (counts.get(s) ?? 0) + 1);
}
const tiles = ['Volaille', 'Viande', 'Legume', 'Poisson', 'Dessert', 'Surgelé'].map((c) => ({
  ...CATEGORIES[c],
  count: counts.get(CATEGORIES[c].slug) ?? 0,
}));

const totalReviews = recipes.reduce((n, r) => n + (r.data.reviews ?? 0), 0);

const title = `${SITE.name} — Recettes & temps de cuisson air fryer`;
const description = SITE.description;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/recettes/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---
<Layout title={title} description={description} path="/" jsonLd={jsonLd}>
  <div class="wrap">
    <section class="hero">
      <div>
        <span class="badge">🔥 {recipes.length} recettes testées</span>
        <h1>Réussissez tout à <span>l'air fryer</span>, du premier coup.</h1>
        <p>Temps de cuisson exacts, températures et astuces testées en cuisine. Zéro devinette, juste des résultats croustillants.</p>
        <div>
          <a href="/recettes/" class="cta">Voir les recettes →</a>
          <a href="/temps-de-cuisson/" class="cta ghost">Temps de cuisson</a>
        </div>
        <div class="rating">
          <span class="stars">★★★★★</span>
          <span>Plus de {totalReviews.toLocaleString('fr-FR')} avis de lecteurs</span>
        </div>
      </div>
      <picture>
        <source type="image/webp" srcset="/img/w/air-fryer-appareil-380.webp 380w, /img/w/air-fryer-appareil-760.webp 760w" sizes="(max-width: 800px) 100vw, 560px" />
        <img src="/img/air-fryer-appareil.jpg" alt="Air fryer sur un plan de travail de cuisine" width="560" height="340" style="height:340px;object-fit:cover;border-radius:20px" fetchpriority="high" decoding="async" />
      </picture>
    </section>

    <div class="trust">
      <span><b>Testé</b> avant publication</span>
      <span><b>Temps & °C</b> précis</span>
      <span><b>Sans</b> bain d'huile</span>
      <span><b>Maison</b> & surgelés</span>
    </div>

    <section>
      <div class="row">
        <div class="h2">Explorer par catégorie<small>Trouvez la cuisson idéale par type d'aliment</small></div>
        <a href="/recettes/" class="seeall">Tout voir →</a>
      </div>
      <div class="cattiles">
        {tiles.map((t) => (
          <a class="tile" href={`/categorie/${t.slug}/`}>
            <div class="ph"><span>{t.label}</span></div>
            <p>{t.label}<br /><span style="color:var(--muted);font-weight:600">{t.count} recettes</span></p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <div class="row">
        <div class="h2">Dernières recettes<small>Fraîchement testées et publiées</small></div>
        <a href="/recettes/" class="seeall">Tout voir →</a>
      </div>
      <div class="cards">
        {latest.map((r, i) => <RecipeCard recipe={r} eager={i < 4} />)}
      </div>
    </section>

    <section>
      <div class="tool">
        <div class="txt">
          <h3>Convertisseur four → air fryer</h3>
          <p>Une recette pensée pour le four ? Obtenez la température et le temps ajustés pour l'air fryer en un clic, plus le tableau des temps par aliment.</p>
          <a href="/temps-de-cuisson/" class="cta">Ouvrir l'outil →</a>
        </div>
        <div class="ph"><span>Convertisseur</span></div>
      </div>
    </section>

    <section>
      <div class="author">
        <div class="avatar">AG</div>
        <p><b>Chaque recette est testée dans notre cuisine.</b> Nous notons le temps et la température exacts, les pièges à éviter et les variantes surgelées — puis on publie. Pas de recette au hasard.</p>
      </div>
    </section>
  </div>
</Layout>
