---
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const GROUPS = {
    viandes:  { title: 'Viandes & volailles', emoji: '🍗', cats: ['Viande', 'Volaille', 'Charcuterie'],
      desc: "Toutes nos recettes de viandes, volailles et charcuteries au air fryer : poulet, bœuf, porc, canard, saucisses… dorés et juteux, avec les temps de cuisson exacts." },
    poissons: { title: 'Poissons & fruits de mer', emoji: '🐟', cats: ['Poisson'],
      desc: "Recettes de poissons et fruits de mer au air fryer : saumon, cabillaud, dorade, gambas, Saint-Jacques… moelleux et sans odeur, avec les temps de cuisson précis." },
    legumes:  { title: 'Légumes', emoji: '🥦', cats: ['Legume'],
      desc: "Recettes de légumes au air fryer : rôtis, croustillants et pleins de saveur, sans huile ou presque. Tous les temps de cuisson pour chaque légume." },
    surgeles: { title: 'Surgelés', emoji: '❄️', cats: ['Surgelé'],
      desc: "Cuire les surgelés au air fryer : frites, nuggets, poisson pané, légumes… croustillants sans décongeler ni bain de friture." },
    desserts: { title: 'Desserts', emoji: '🍰', cats: ['Dessert'],
      desc: "Desserts au air fryer : gâteaux, moelleux, cookies, viennoiseries, flans… gourmands et rapides, sans allumer le four." },
    apero:    { title: 'Apéro', emoji: '🧀', cats: ['Apéro'],
      desc: "Recettes apéro au air fryer : bouchées croustillantes, feuilletés, fromages panés, bruschetta… parfaits à partager, sans friture." },
    plats:    { title: 'Plats & accompagnements', emoji: '🍽️', cats: ['Plat', 'Accompagnement', 'Œufs'],
      desc: "Plats complets, accompagnements et œufs au air fryer : wraps, gratins, pommes de terre, omelettes… le repas facile de tous les jours." },
  };
  return Object.entries(GROUPS).map(([slug, g]) => ({ params: { slug }, props: { g } }));
}

const { g } = Astro.props;
const recipes = (await getCollection('recipes'))
  .filter((r) => r.data.pubDate.getTime() <= Date.now() && g.cats.includes(r.data.category))
  .sort((a, b) => b.data.reviews - a.data.reviews);
---
<Base title={`Recettes ${g.title} au air fryer — Airfryer Gourmand`} description={g.desc}>
  <div class="wrap">
    <section style="padding-top:26px">
      <div class="crumb" style="color:#9a8c7d;font-size:.9rem;margin-bottom:10px">
        <a href="/" style="color:var(--accent);text-decoration:none">Accueil</a> ›
        <a href="/recettes/" style="color:var(--accent);text-decoration:none">Recettes</a> › {g.title}
      </div>
      <div class="row"><h1 class="h2">{g.emoji} {g.title}<small>{recipes.length} recette{recipes.length > 1 ? 's' : ''} au air fryer</small></h1></div>
      <p style="max-width:720px;color:#6a5d54;margin:0 0 20px">{g.desc}</p>
      {recipes.length > 0 ? (
        <div class="cards">
          {recipes.map((r) => <RecipeCard title={r.data.title} category={r.data.category} rating={r.data.rating} cookTime={r.data.cookTime} slug={r.slug} image={r.data.image} />)}
        </div>
      ) : (
        <p style="color:#6a5d54">De nouvelles recettes arrivent très bientôt dans cette catégorie. En attendant, découvre <a href="/recettes/" style="color:var(--accent)">toutes nos recettes</a>.</p>
      )}
    </section>
  </div>
</Base>
