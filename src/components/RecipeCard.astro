---
export interface Props { title:string; category:string; rating:number; cookTime:number; slug:string; image?:string; }
const { title, category, rating, cookTime, slug, image } = Astro.props;
---
<a class="rcard" href={`/recettes/${slug}/`}>
  <div class="pin" aria-hidden="true">📌</div>
  {image
    ? <img src={image} alt={title} loading="lazy" style="height:150px;width:100%;object-fit:cover;display:block" />
    : <div class="ph"><span>📷 Photo</span></div>}
  <div class="rbody">
    <div class="rtag">{category}</div>
    <h3>{title}</h3>
    <div class="rmeta">
      <span class="stars">★ {rating.toFixed(1)}</span>
      <span class="time">⏱️ {cookTime} min</span>
    </div>
  </div>
</a>
